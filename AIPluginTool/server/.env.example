PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Production: comma-separated origins, e.g. https://app.example.com
# CLIENT_ORIGIN=https://your-app.onrender.com

NODE_ENV=development
SERVE_CLIENT=false
TRUST_PROXY=false
COOKIE_SECURE=false

# Authentication (set AUTH_ENABLED=true for login screen)
AUTH_ENABLED=true
AUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
# Demo admin (defaults if left blank while AUTH_ENABLED=true)
AUTH_EMAIL=admin@demo.local
AUTH_PASSWORD=Admin12345!
# Or use a pre-hashed password from: npm run hash-password -w server -- "your-password"
# AUTH_PASSWORD_HASH=

SESSION_MAX_AGE_HOURS=168

# cloudflare | openai
LLM_PROVIDER=cloudflare

# Cloudflare Workers AI (recommended)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
# Vision model for extension page screenshots (eye icon)
# CLOUDFLARE_VISION_MODEL=@cf/llava-hf/llava-1.5-7b-hf

# Vectorize RAG (create index first — see CLOUDFLARE_VECTORIZE.md)
# VECTORIZE_ENABLED=true
VECTORIZE_INDEX_NAME=cia-transition-kb
CLOUDFLARE_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5
RAG_TOP_K=8

REQUEST_TIMEOUT_MS=30000
DB_PATH=./data/chat.db
