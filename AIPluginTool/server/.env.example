PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Production: comma-separated origins, e.g. https://app.example.com
# CLIENT_ORIGIN=https://your-app.onrender.com

NODE_ENV=development
SERVE_CLIENT=false
TRUST_PROXY=false
COOKIE_SECURE=false

# Authentication (set AUTH_ENABLED=true for login screen)
AUTH_ENABLED=true
AUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
# Demo admin (defaults if left blank while AUTH_ENABLED=true)
AUTH_EMAIL=admin@demo.local
AUTH_PASSWORD=Admin12345!
# Or use a pre-hashed password from: npm run hash-password -w server -- "your-password"
# AUTH_PASSWORD_HASH=

SESSION_MAX_AGE_HOURS=168

# cloudflare | openai
LLM_PROVIDER=cloudflare

# Cloudflare Workers AI (recommended)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
# Vision model for extension page screenshots (eye icon)
# CLOUDFLARE_VISION_MODEL=@cf/llava-hf/llava-1.5-7b-hf

# Vectorize RAG (create index first — see CLOUDFLARE_VECTORIZE.md)
# VECTORIZE_ENABLED=true
VECTORIZE_INDEX_NAME=cia-transition-kb
CLOUDFLARE_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5
RAG_TOP_K=8

REQUEST_TIMEOUT_MS=30000
DB_PATH=./data/chat.db

# --- App connectors (OAuth) ---
# Public base URL of THIS server, used to build OAuth redirect URIs.
PUBLIC_SERVER_URL=http://localhost:3001

# Google Drive — console.cloud.google.com → APIs & Services → Credentials → OAuth client (Web)
# Authorized redirect URI: ${PUBLIC_SERVER_URL}/api/connectors/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# Microsoft (OneDrive, SharePoint, Teams) — portal.azure.com → App registrations
# Redirect URI (Web): ${PUBLIC_SERVER_URL}/api/connectors/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
# MICROSOFT_REDIRECT_URI=

# Atlassian (Jira, Confluence) — developer.atlassian.com → OAuth 2.0 (3LO) app
# Callback URL: ${PUBLIC_SERVER_URL}/api/connectors/callback/atlassian
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# ATLASSIAN_REDIRECT_URI=

# Microsoft Copilot Studio (Direct Line) — optional agent connector
# Publish your agent in Copilot Studio, then Channels → Direct Line → copy secret.
# In Settings, choose "Copilot Studio agent" as the AI provider.
# COPILOT_STUDIO_ENABLED=true
# COPILOT_STUDIO_DIRECT_LINE_SECRET=
# COPILOT_STUDIO_AGENT_NAME=CiA Transition Agent
