{
  "manifest_version": 3,
  "name": "CiA Transition Assistant",
  "short_name": "CiA Assistant",
  "description": "AI-powered Ci → CiA transition helper. Click the floating bubble or right-click any selection to ask the assistant.",
  "version": "0.1.0",
  "version_name": "0.1.0-dev",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Toggle CiA Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "options_page": "src/options/index.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.js-_o2FHpzX.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "js": [
        "assets/floating-widget.js-NhhmHuIR.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "sidePanel",
    "storage",
    "unlimitedStorage",
    "contextMenus",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "icons/*",
        "src/sidepanel/index.html",
        "assets/*",
        "assets/index.js-_o2FHpzX.js",
        "assets/floating-widget.js-NhhmHuIR.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
